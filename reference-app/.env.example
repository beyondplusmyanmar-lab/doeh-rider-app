# Everything here is PUBLIC: EXPO_PUBLIC_* values are inlined into the bundle at
# build time. There are NO secrets in this app.
#
# The rider (fulfillment) API host. Default is the public sandbox; point it at
# your own shop's POS domain for a real run.
EXPO_PUBLIC_RIDER_API_URL=https://rider-sandbox.doehpos.com

# Convenience prefill for the login screen so the sandbox is one tap. These are
# the PUBLISHED Phase B demo-rider credentials — safe to commit. Blank them out
# for a real shop (the rider types their own).
EXPO_PUBLIC_RIDER_DEMO_EMAIL=rider@sandbox.test
EXPO_PUBLIC_RIDER_DEMO_PASSWORD=sandbox-rider-pass
