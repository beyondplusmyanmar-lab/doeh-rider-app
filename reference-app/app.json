{
  "expo": {
    "name": "DOEH Rider",
    "slug": "doeh-rider-reference",
    "scheme": "doehrider",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0b1020"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doeh.rider.reference"
    },
    "android": {
      "package": "com.doeh.rider.reference"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
